# =============================================================================
# LOREMASTER ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in the values
# DO NOT commit .env to version control
#
# ARCHITECTURE:
#   Development: Local PostgreSQL (Docker) + Local services
#   Production:  Supabase (PostgreSQL) + Fly.io (Backend & Genkit) + Vercel (Frontend)

# =============================================================================
# ENVIRONMENT
# =============================================================================
ASPNETCORE_ENVIRONMENT=Development
NODE_ENV=development

# =============================================================================
# DATABASE - DEVELOPMENT (Local Docker PostgreSQL)
# =============================================================================
# Start with: docker-compose -f docker-compose.dev.yml up -d
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=loremaster
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Connection string for .NET backend (Development)
# This is used when ASPNETCORE_ENVIRONMENT=Development
DATABASE_CONNECTION_STRING=Host=localhost;Port=5432;Database=loremaster;Username=postgres;Password=postgres

# =============================================================================
# DATABASE - PRODUCTION (Supabase)
# =============================================================================
# 1. Create a project at https://supabase.com
# 2. Go to Settings > Database > Connection string > URI
# 3. Use the "Connection pooling" string (port 6543) for production
# 4. Enable pgvector extension: SQL Editor > Run: CREATE EXTENSION IF NOT EXISTS vector;
#
# Format: Host=db.[ref].supabase.co;Port=6543;Database=postgres;Username=postgres.[ref];Password=[password];SSL Mode=Require;Trust Server Certificate=true;Pooling=true;Minimum Pool Size=0;Maximum Pool Size=100
#
# For Fly.io, set as secret:
#   fly secrets set ConnectionStrings__SupabaseConnection="Host=..."
#
SUPABASE_CONNECTION_STRING=

# =============================================================================
# JWT AUTHENTICATION (User tokens)
# =============================================================================
# IMPORTANT: Generate strong secrets for production (min 32 characters)
# Generate with: openssl rand -base64 32
#
# For Fly.io, set as secret:
#   fly secrets set Jwt__Secret="your-secret-here"
#
JWT_SECRET=DEVELOPMENT_SECRET_KEY_DO_NOT_USE_IN_PRODUCTION_32CHARS
JWT_ISSUER=Loremaster
JWT_AUDIENCE=Loremaster
JWT_ACCESS_TOKEN_EXPIRATION_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRATION_DAYS=7

# =============================================================================
# SERVICE JWT (Service-to-service communication: Backend <-> Genkit)
# =============================================================================
# Must be the same on both Backend and Genkit services
#
# For Fly.io, set on BOTH apps:
#   fly secrets set ServiceJwt__Secret="your-service-secret" --app loremaster-api
#   fly secrets set SERVICE_JWT_SECRET="your-service-secret" --app loremaster-genkit
#
SERVICE_JWT_SECRET=DEV_SERVICE_SECRET_KEY_DO_NOT_USE_IN_PRODUCTION_32
SERVICE_JWT_ISSUER=Loremaster.Api
SERVICE_JWT_AUDIENCE=Loremaster.Genkit
SERVICE_JWT_EXPIRATION_MINUTES=5

# =============================================================================
# GENKIT AI SERVICE
# =============================================================================
# Development: Local Genkit service
GENKIT_SERVICE_URL=http://localhost:3000
GENKIT_SERVICE_TIMEOUT_SECONDS=30

# Production: Fly.io internal DNS (set in fly.toml, not here)
# The backend will automatically use http://loremaster-genkit.internal:3000

# Google AI API Key (required for Genkit)
# Get from: https://aistudio.google.com/apikey
#
# For Fly.io Genkit service:
#   fly secrets set GOOGLE_GENAI_API_KEY="your-key" --app loremaster-genkit
#
GOOGLE_GENAI_API_KEY=your_google_ai_api_key_here

# =============================================================================
# CORS (Cross-Origin Resource Sharing)
# =============================================================================
# Development: Local frontend URLs
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Production: Set your Vercel domain
# For Fly.io:
#   fly secrets set Cors__Origins__0="https://your-app.vercel.app" --app loremaster-api
#
# CORS_ORIGINS=https://your-app.vercel.app

# =============================================================================
# RATE LIMITING
# =============================================================================
RATE_LIMIT_ENABLED=false
RATE_LIMIT_PERMIT=100
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_QUEUE=10

# =============================================================================
# FRONTEND (Vite)
# =============================================================================
# Development: Vite proxy forwards /api requests to the backend
# No VITE_API_URL needed - the proxy handles it
VITE_BACKEND_URL=http://localhost:5000

# Production (Vercel): Set the full API URL
# VITE_API_URL=https://loremaster-api.fly.dev/api

# App name
VITE_APP_NAME=HefestAI

# =============================================================================
# DOCKER PORTS (for docker-compose)
# =============================================================================
BACKEND_PORT=5000
FRONTEND_PORT=5173
GENKIT_PORT=3000
