# Genkit service environment
PORT=3000
NODE_ENV=development

# Google AI API Key (get from https://aistudio.google.com/apikey)
GOOGLE_GENAI_API_KEY=your_api_key_here

# JWT Configuration for service-to-service authentication
# This secret should match the ServiceJwt:Secret in ASP.NET backend
JWT_SECRET=your_service_jwt_secret_at_least_32_characters_long
JWT_ISSUER=Loremaster.Api
JWT_AUDIENCE=Loremaster.Genkit

# Allowed scopes (comma-separated)
ALLOWED_SCOPES=genkit.execute,genkit.admin

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5000,http://localhost:5173

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
