# Frontend Environment Variables (Development)
# Copy to .env.local and fill in values

# =============================================================================
# DEVELOPMENT (with Vite proxy)
# =============================================================================
# Backend URL for Vite proxy (without /api suffix)
# The frontend uses relative /api paths, Vite proxies them to this URL
VITE_BACKEND_URL=http://localhost:5000

# =============================================================================
# PRODUCTION (Vercel)
# =============================================================================
# In production, set VITE_API_URL to the full backend API URL
# This is used when the proxy is not available (production build)
# Example: VITE_API_URL=https://loremaster-api.fly.dev/api
VITE_API_URL=

# =============================================================================
# APP CONFIG
# =============================================================================
VITE_APP_NAME=HefestAI
